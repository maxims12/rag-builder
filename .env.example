# RAG System Builder — environment template.
# Copy to .env (`cp .env.example .env`) and fill in real values.
# docker-compose.yml reads this via `env_file: .env`. Never commit your real .env.

# ─── Ports (host side) ───────────────────────────────────────────────
BACKEND_PORT=8000          # host port -> backend container :8000
FRONTEND_PORT=3000         # host port -> frontend container :3000
VECTORSTORE_PORT=6333      # host port -> vectorstore container :6333

# ─── Frontend ────────────────────────────────────────────────────────
# Base path the browser uses; next.config rewrites proxy /api -> backend.
NEXT_PUBLIC_API_BASE_URL=/api
# Internal URL the Next.js server uses to reach the backend over the
# compose network (overridden in compose; set for local `next dev`).
BACKEND_INTERNAL_URL=http://backend:8000

# ─── Auth (Phase 2) ──────────────────────────────────────────────────
# Generate a strong secret: `openssl rand -hex 32`
JWT_SECRET=change_me_to_a_long_random_string
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7

# ─── Seed admin (created on first boot, Phase 1) ─────────────────────
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=change_this_password

# ─── Backend core (Phase 1) ──────────────────────────────────────────
# SQLite lives in the mounted /app/data volume so it survives restarts.
DATABASE_URL=sqlite:///./data/rag_builder.db
CORS_ORIGINS=http://localhost:3000
LOG_LEVEL=INFO

# ─── Vector store ────────────────────────────────────────────────────
# Backend reaches vectorstore over the compose network (QDRANT_URL is
# overridden in compose; set for local `uvicorn` development).
QDRANT_URL=http://localhost:6333

# ─── LLM / Embedding API keys (only fill in what you use) ────────────
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
COHERE_API_KEY=
GROQ_API_KEY=
VOYAGE_API_KEY=
